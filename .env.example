# Server Configuration
STUDIO_SERVER_PORT=8080
STUDIO_SERVER_MODE=debug
STUDIO_SERVER_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080

# Database Configuration
# For production, use sslmode=require or sslmode=verify-full
STUDIO_DATABASE_DSN=postgres://studio:password@localhost:5432/studio_db?sslmode=prefer
STUDIO_DATABASE_MAX_CONNS=20
STUDIO_DATABASE_MIN_CONNS=5

# Redis Configuration
STUDIO_REDIS_ADDR=localhost:6379
STUDIO_REDIS_PASSWORD=redis_secure_password_change_me
STUDIO_REDIS_DB=0

# JWT Configuration
# IMPORTANT: Generate a secure random string for production
# Example: openssl rand -base64 32
STUDIO_JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
STUDIO_JWT_ACCESS_EXPIRY=15m
STUDIO_JWT_REFRESH_EXPIRY=720h

# OSS (Object Storage Service) Configuration
# Aliyun OSS / AWS S3 / MinIO
STUDIO_OSS_PROVIDER=aliyun
STUDIO_OSS_ACCESS_KEY_ID=your_access_key_id
STUDIO_OSS_ACCESS_KEY_SECRET=your_access_key_secret
STUDIO_OSS_BUCKET=your_bucket_name
STUDIO_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
STUDIO_OSS_REGION=cn-hangzhou

# Rate Limiting Configuration
# Requests per minute
STUDIO_RATELIMIT_UNAUTHENTICATED=60
STUDIO_RATELIMIT_AUTHENTICATED=200
STUDIO_RATELIMIT_ADMIN=1000

# Backup Configuration (for scripts)
STUDIO_DATABASE_NAME=studio_db
STUDIO_DATABASE_USER=studio
STUDIO_DATABASE_HOST=localhost
STUDIO_DATABASE_PORT=5432
STUDIO_DATABASE_PASSWORD=password
BACKUP_RETENTION_DAYS=7
