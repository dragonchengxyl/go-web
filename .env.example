# Server
STUDIO_SERVER_PORT=8080
STUDIO_SERVER_MODE=debug

# Database
STUDIO_DATABASE_DSN=postgres://studio:password@localhost:5432/studio_db?sslmode=disable
STUDIO_DATABASE_MAX_CONNS=20
STUDIO_DATABASE_MIN_CONNS=5

# Redis
STUDIO_REDIS_ADDR=localhost:6379
STUDIO_REDIS_PASSWORD=
STUDIO_REDIS_DB=0

# JWT
STUDIO_JWT_SECRET=your-secret-key-change-in-production
STUDIO_JWT_ACCESS_EXPIRY=15m
STUDIO_JWT_REFRESH_EXPIRY=720h

# OSS (Object Storage)
STUDIO_OSS_PROVIDER=aliyun
STUDIO_OSS_ACCESS_KEY_ID=
STUDIO_OSS_ACCESS_KEY_SECRET=
STUDIO_OSS_BUCKET=
STUDIO_OSS_ENDPOINT=
STUDIO_OSS_REGION=

# Rate Limit
STUDIO_RATELIMIT_UNAUTHENTICATED=60
STUDIO_RATELIMIT_AUTHENTICATED=200
STUDIO_RATELIMIT_ADMIN=1000
